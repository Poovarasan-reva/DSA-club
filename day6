import java.util.Scanner;

public class CustomerRatingAverage {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        double[] ratings = new double[5];
        System.out.println("Enter 5 customer ratings (0-5 scale):");
        for(int i = 0; i < 5; i++) {
            System.out.print("Rating " + (i+1) + ": ");
            ratings[i] = sc.nextDouble();
        }
        double sum = 0.0;
        for (double rating : ratings) {
            sum += rating;
        }
        double average = sum / ratings.length;
        System.out.println("\nRatings entered: " + java.util.Arrays.toString(ratings));
        System.out.printf("Average customer rating: %.2f%n", average);
        sc.close();
    }
}

import java.util.Scanner;

public class EvenOddCount {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

        int[] sales = new int[8];
        int evenCount = 0, oddCount = 0;

        System.out.println("Enter 8 sales values:");

        for (int i = 0; i < 8; i++) {
            sales[i] = sc.nextInt();
        }

        for (int i = 0; i < 8; i++) {
            if (sales[i] % 2 == 0) {
                evenCount++;
            } else {
                oddCount++;
            }
        }

        System.out.println("Even numbers count: " + evenCount);
        System.out.println("Odd numbers count: " + oddCount);

        sc.close();
    }
}

import java.util.Scanner;

public class SeatAvailability {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);

        int[] bookedSeats = {2, 5, 8, 10, 15};

        System.out.print("Enter seat number to check: ");
        int requestedSeat = sc.nextInt();

        boolean isBooked = false;

        for (int seat : bookedSeats) {
            if (seat == requestedSeat) {
                isBooked = true;
                break;
            }
        }

        if (isBooked) {
            System.out.println("Seat " + requestedSeat + " is NOT available (already booked).");
        } else {
            System.out.println("Seat " + requestedSeat + " is available.");
        }

        sc.close();
    }
}

import java.util.Scanner;

public class ReverseTemperature {
    public static void main(String[] args) {

        Scanner sc = new Scanner(System.in);
        System.out.print("Enter number of temperature readings: ");
        int n = sc.nextInt();

        int[] temp = new int[n];
        System.out.println("Enter temperature readings:");
        for (int i = 0; i < n; i++) {
            temp[i] = sc.nextInt();
        }
        int start = 0;
        int end = n - 1;

        while (start < end) {
            int tempValue = temp[start];
            temp[start] = temp[end];
            temp[end] = tempValue;

            start++;
            end--;
        }
        System.out.println("Reversed Temperature Readings:");
        for (int t : temp) {
            System.out.print(t + " ");
        }

        sc.close();
    }
}

