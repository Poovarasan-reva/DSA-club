import java.util.Scanner;

public class CheckHeightsSorted {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter number of players: ");
        int n = sc.nextInt();

        int[] heights = new int[n];
        System.out.println("Enter player heights (in cm):");
        for (int i = 0; i < n; i++) {
            heights[i] = sc.nextInt();
        }
        boolean isSorted = true;
        for (int i = 0; i < n - 1; i++) {
            if (heights[i] > heights[i + 1]) {
                isSorted = false;
                break;
            }
        }
        if (isSorted) {
            System.out.println("The heights are sorted in ascending order.");
        } else {
            System.out.println("The heights are NOT sorted.");
        }

        sc.close();
    }
}

import java.util.Scanner;

public class VowelCounter {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        System.out.print("Enter student name: ");
        String name = sc.nextLine();
        name = name.toLowerCase();

        int vowelCount = 0;
        for (int i = 0; i < name.length(); i++) {
            char ch = name.charAt(i);
            if (ch == 'a' || ch == 'e' || ch == 'i' || ch == 'o' || ch == 'u') {
                vowelCount++;
            }
        }


        System.out.println("Number of vowels in the name: " + vowelCount);

        sc.close();
    }
}

import java.util.Scanner;

public class ReverseMessage {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);

       
        System.out.print("Enter a message: ");
        String message = sc.nextLine();
        char[] chars = message.toCharArray();

        int start = 0;
        int end = chars.length - 1;
        while (start < end) {
            char temp = chars[start];
            chars[start] = chars[end];
            chars[end] = temp;
            start++;
            end--;
        }

        String reversedMessage = new String(chars);

        System.out.println("Reversed message: " + reversedMessage);

        sc.close();
    }
}

